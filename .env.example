# =============================================================================
# FIDC Insight · Variáveis de ambiente (template)
# =============================================================================
# Copie este arquivo para `.env` e preencha com seus valores reais.
# O arquivo `.env` NÃO deve ser commitado (já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# BigQuery
# -----------------------------------------------------------------------------
BQ_PROJECT_ID=dataversenuclea
BQ_DATASET=fidc_dataset
BQ_TABLE_CARTEIRA=tb_score_consolidado
BQ_TABLE_HISTORICO=tb_historico_precificacoes

# -----------------------------------------------------------------------------
# Cache (em segundos)
# -----------------------------------------------------------------------------
CACHE_TTL_CARTEIRA=1800   # 30 min
CACHE_TTL_SELIC=3600      # 1 hora

# -----------------------------------------------------------------------------
# Autenticação Google Cloud (opcional — apenas se não usar gcloud CLI)
# -----------------------------------------------------------------------------
# Descomente e aponte para um arquivo JSON de Service Account se preferir
# autenticar por chave em vez de rodar `gcloud auth application-default login`.
#
# GOOGLE_APPLICATION_CREDENTIALS=credenciais.json
